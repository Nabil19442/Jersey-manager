{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Customer order for jerseys",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "jerseyName": { "type": "string" },
        "teamName": { "type": "string" },
        "size": { "type": "string" },
        "quantity": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "buyingCost": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "otherExpense": { "type": "number" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "phoneNumber", "address", "jerseyName", "teamName", "size", "quantity", "sellingPrice", "buyingCost", "deliveryCharge", "status", "paymentStatus", "date", "createdAt"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Jersey stock item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "team": { "type": "string" },
        "season": { "type": "string" },
        "size": { "type": "array" },
        "stockQuantity": { "type": "number" },
        "buyingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "team", "season", "size", "stockQuantity", "buyingPrice", "sellingPrice", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense record",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "amount", "category", "date", "createdAt"]
    }
  },
  "firestore": {
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "inventory": {
      "schema": "InventoryItem",
      "description": "Collection of inventory items"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Collection of business expenses"
    }
  }
}
